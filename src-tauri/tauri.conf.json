{
  "productName": "快捷总结笔记",
  "version": "1.1.0",
  "identifier": "com.quicksummary.desktop",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "快捷总结笔记",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "shortDescription": "AI对话总结工具",
    "longDescription": "通过AI自动总结对话内容，支持多种模型",
    "category": "Productivity",
    "icon": [
      "32x32",
      "128x128",
      "128x128@2x",
      "256x256",
      "256x256@2x",
      "512x512",
      "512x512@2x",
      "1024x1024",
      "1024x1024@2x",
      "icon.icns"
    ],
    "externalBin": [
      "binaries/summarizer",
      "binaries/api-server"
    ],
    "resources": [
      "binaries/*",
      "../config/*",
      "../logs/.gitkeep",
      "../ui/*"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
